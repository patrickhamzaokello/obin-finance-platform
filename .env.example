# Copy this file to .env.production and fill in real values.
# Never commit .env.production.

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=https://your-domain.com

# ── Database (used by the app container) ──────────────────────────────────────
# If using the bundled postgres service, docker-compose sets this automatically.
# For an external DB (Neon, RDS, etc.) paste the connection string here.
DATABASE_URL=postgres://obin:changeme@postgres:5432/obin_finance

# ── Postgres service credentials (only needed if using bundled postgres) ──────
POSTGRES_USER=obin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=obin_finance

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=learningplatform
AWS_CLOUDFRONT_DOMAIN=https://your-cf-domain.cloudfront.net

# ── Vercel Blob (legacy — only needed if old blob URLs still exist) ───────────
BLOB_READ_WRITE_TOKEN=
